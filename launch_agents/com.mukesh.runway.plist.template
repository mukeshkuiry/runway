<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mukesh.runway</string>

  <!-- Replace __PROGRAM_PATH__ with an absolute path to the Runway executable on your machine -->
  <key>Program</key>
  <string>__PROGRAM_PATH__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/runway.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/runway.err.log</string>
</dict>
</plist>
